{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A luxury football jersey",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the jersey" },
        "description": { "type": "string", "description": "Product details" },
        "price": { "type": "number", "description": "Selling price" },
        "costPrice": { "type": "number", "description": "Cost to brand" },
        "stock": { "type": "integer", "description": "Available inventory" },
        "imageUrl": { "type": "string", "description": "URL to the product image" },
        "images": { "type": "array", "description": "List of secondary images" },
        "gender": { "type": "string" },
        "club": { "type": "string" },
        "country": { "type": "string" },
        "category": { "type": "string", "enum": ["Official", "Retro", "Embroidery", "HighQuality", "Sale", "LimitedEdition", "PlayerEdition", "Club", "NationalTeam", "CustomName", "TrainingKits", "Shorts", "Socks"] },
        "isFeatured": { "type": "boolean" },
        "isTrending": { "type": "boolean" },
        "ratings": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "costPrice", "stock", "category"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "deliveryFee": { "type": "number" },
        "paymentMethod": { "type": "string", "enum": ["cod", "online", "balance"] },
        "paymentDetails": { "type": "object", "properties": { "transactionId": { "type": "string" }, "proofUrl": { "type": "string" } } },
        "status": { "type": "string", "enum": ["pending", "verifying", "processing", "shipped", "delivered", "cancelled"] },
        "estimatedDelivery": { "type": "string" },
        "shippingAddress": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "total", "status", "paymentMethod"]
    },
    "BalanceRequest": {
      "title": "BalanceRequest",
      "description": "Request to add funds via QR",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "transactionId": { "type": "string" },
        "proofImageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "status"]
    },
    "GiftCard": {
      "title": "GiftCard",
      "description": "Redeemable credit code",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "value": { "type": "number" },
        "createdBy": { "type": "string" },
        "isRedeemed": { "type": "boolean" },
        "redeemedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "Support channel message",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "isAdmin": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "Detailed user profile for WH1RLPOOL",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "balance": { "type": "number" },
        "profileImage": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "zipcode": { "type": "string" },
        "country": { "type": "string" },
        "preferredSize": { "type": "string" },
        "gender": { "type": "string" },
        "preferredPayment": { "type": "string" },
        "totalSpending": { "type": "number", "description": "Total amount spent by the user across all orders" },
        "loyaltyPoints": { "type": "number", "description": "Accumulated loyalty points based on spending" },
        "wh1rlCoins": { "type": "number", "description": "Currency earned: 1 coin per ₹1 spent" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "UserPrivateInfo": {
      "title": "UserPrivateInfo",
      "description": "Sensitive user information",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "address": { "type": "string" }
      }
    }
  },
  "firestore": {
    "products/{productId}": {
      "schema": "Product",
      "description": "Collection of jerseys"
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "balance_requests/{requestId}": {
      "schema": "BalanceRequest",
      "description": "Wallet addition requests"
    },
    "users/{userId}/public/profile": {
      "schema": "UserProfile",
      "description": "Public profile of a user"
    },
    "users/{userId}/private/info": {
      "schema": "UserPrivateInfo",
      "description": "Private sensitive data of a user"
    }
  }
}
