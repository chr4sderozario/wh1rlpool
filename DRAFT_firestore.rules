rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isEmailVerified() && (
        request.auth.token.email == 'sohanbiswas@chr4s.com' ||
        request.auth.token.email == 'johnrozario@chr4s.com'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'stock']) &&
             data.keys().size() <= 7 &&
             data.name is string && data.name.size() <= 100 &&
             data.price is number && data.price >= 0 &&
             data.stock is int && data.stock >= 0 &&
             (!('description' in data) || (data.description is string && data.description.size() <= 1000)) &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() <= 500)) &&
             (!('category' in data) || (data.category is string && data.category.size() <= 50));
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'items', 'total', 'status']) &&
             data.keys().size() <= 6 &&
             data.userId == request.auth.uid &&
             data.items is list && data.items.size() > 0 && data.items.size() <= 50 &&
             data.total is number && data.total >= 0 &&
             data.status in ['pending', 'shipped', 'delivered', 'cancelled'] &&
             (!('createdAt' in data) || data.createdAt == request.time);
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['displayName', 'role', 'createdAt']) &&
             data.keys().size() == 3 &&
             data.displayName is string && data.displayName.size() <= 50 &&
             data.role in ['admin', 'user'] &&
             data.createdAt == request.time;
    }

    function isValidUserPrivateInfo(data) {
      return data.keys().hasAll(['email']) &&
             data.keys().size() <= 3 &&
             data.email is string && data.email.size() <= 100;
    }

    // --- Collection Rules ---

    match /products/{productId} {
      allow read: if true; 
      allow create: if isAdmin() && isValidId(productId) && isValidProduct(incoming());
      allow update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow get: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isEmailVerified() && isValidId(orderId) && isValidOrder(incoming());
      allow update: if isAdmin() && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
        incoming().status in ['shipped', 'delivered', 'cancelled']
      );
      allow delete: if false; // Orders should be retained
    }

    match /users/{userId} {
      match /public/profile {
        allow read: if isSignedIn();
        allow create: if isOwner(userId) && isValidUserProfile(incoming()) && incoming().role == 'user';
        allow update: if isOwner(userId) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['displayName']) &&
                      isValidUserProfile(incoming());
        allow delete: if false;
      }

      match /private/info {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) && isValidUserPrivateInfo(incoming());
      }
    }
  }
}
