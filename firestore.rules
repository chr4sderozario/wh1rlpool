rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isEmailVerified() && (
        request.auth.token.email == 'sohanbiswas@chr4s.com' ||
        request.auth.token.email == 'johnrozario@chr4s.com'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'costPrice', 'stock', 'category']) &&
             data.keys().size() >= 5 && data.keys().size() <= 10 &&
             data.name is string && data.name.size() > 0 &&
             data.price is number && data.price >= 0 &&
             data.costPrice is number && data.costPrice >= 0 &&
             data.stock is int && data.stock >= 0 &&
             data.category in ['Jersey', 'Pants', 'Embroidery', 'OnSale', 'Accessories'] &&
             (!('description' in data) || data.description is string) &&
             (!('imageUrl' in data) || data.imageUrl is string) &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    function isValidUserProfile(data) {
      return data.keys().size() <= 16 &&
             (!('displayName' in data) || data.displayName is string) &&
             (!('email' in data) || data.email is string) &&
             (!('phone' in data) || data.phone is string) &&
             (!('whatsapp' in data) || data.whatsapp is string) &&
             (!('address' in data) || data.address is string) &&
             (!('city' in data) || data.city is string) &&
             (!('state' in data) || data.state is string) &&
             (!('country' in data) || data.country is string) &&
             (!('gender' in data) || data.gender in ['Male', 'Female', 'Unisex', 'Other']) &&
             (!('size' in data) || data.size in ['XS', 'S', 'M', 'L', 'XL', 'XXL']) &&
             (!('role' in data) || data.role in ['admin', 'user']) &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'items', 'total', 'status']) &&
             data.keys().size() >= 4 && data.keys().size() <= 8 &&
             data.userId == request.auth.uid &&
             data.items is list && data.items.size() > 0 &&
             data.total is number && data.total >= 0 &&
             data.status in ['pending', 'shipped', 'delivered', 'cancelled'] &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    function isValidUserPrivateInfo(data) {
       return data.keys().size() <= 5 &&
              (!('email' in data) || data.email is string) &&
              (!('stripeId' in data) || data.stripeId is string);
    }

    // --- Collection Rules ---

    match /products/{productId} {
      allow read: if true; 
      allow create: if isAdmin() && isValidId(productId) && isValidProduct(incoming());
      allow update: if isAdmin() && isValidProduct(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'price', 'costPrice', 'description', 'imageUrl', 'category', 'stock'])
      );
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow get: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isEmailVerified() && isValidId(orderId) && isValidOrder(incoming());
      allow update: if isAdmin() && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
        incoming().status in ['shipped', 'delivered', 'cancelled']
      );
      allow delete: if false;
    }

    match /users/{userId} {
      match /public/profile {
        allow get: if isSignedIn();
        allow list: if isAdmin() || (isSignedIn() && resource.data.role == 'user');
        
        allow create: if isOwner(userId) && isValidUserProfile(incoming());
        allow update: if isOwner(userId) && 
                      isValidUserProfile(incoming()) &&
                      (!incoming().diff(existing()).affectedKeys().hasAny(['role', 'createdAt']));
        allow delete: if false;
      }

      match /private/info {
        allow read: if isOwner(userId) || isAdmin();
        // Force server timestamp on update/create if added to schema, for now simple write
        allow write: if isOwner(userId) && isValidUserPrivateInfo(incoming());
      }
    }
  }
}
