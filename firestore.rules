rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isEmailVerified() && (
        request.auth.token.email == 'sohanbiswas@chr4s.com' ||
        request.auth.token.email == 'johnrozario@chr4s.com' ||
        request.auth.token.email == 'johnchristianorozario@gmail.com'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'costPrice', 'stock', 'category']) &&
             data.keys().size() >= 5 && data.keys().size() <= 15 &&
             data.name is string && data.name.size() > 0 &&
             data.price is number && data.price >= 0 &&
             data.costPrice is number && data.costPrice >= 0 &&
             data.stock is int && data.stock >= 0 &&
             data.category in [
               'Official Jerseys', 'Retro Jerseys', 'Embroidery Jerseys', 
               'High Quality Jerseys', 'Sale Jerseys', 'Limited Edition Jerseys', 
               'Player Edition Jerseys', 'Club Jerseys', 'National Team Jerseys', 
               'Custom Name Jerseys', 'Training Kits', 'Shorts', 'Socks'
             ] &&
             (!('description' in data) || data.description is string) &&
             (!('imageUrl' in data) || data.imageUrl is string) &&
             (!('images' in data) || data.images is list) &&
             (!('gender' in data) || data.gender is string) &&
             (!('club' in data) || data.club is string) &&
             (!('country' in data) || data.country is string) &&
             (!('isFeatured' in data) || data.isFeatured is bool) &&
             (!('isTrending' in data) || data.isTrending is bool) &&
             (!('ratings' in data) || data.ratings is number) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp) &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    function isValidGiftCard(data) {
      return data.keys().hasAll(['code', 'amount', 'status']) &&
             data.code is string && data.code.size() == 6 &&
             data.amount is number && data.amount > 0 &&
             data.status in ['active', 'redeemed'] &&
             (!('createdAt' in data) || data.createdAt is timestamp) &&
             (!('requestId' in data) || data.requestId is string);
    }

    function isValidGiftCardRequest(data) {
      return data.keys().hasAll(['userId', 'userName', 'amount', 'status']) &&
             data.userId == request.auth.uid &&
             data.amount is number && data.amount > 0 &&
             data.status in ['pending', 'approved', 'rejected'] &&
             (!('transactionId' in data) || data.transactionId is string) &&
             (!('materializedCode' in data) || data.materializedCode is string) &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    function isValidUserProfile(data) {
      return data.keys().size() <= 20 &&
             (!('displayName' in data) || data.displayName is string) &&
             (!('email' in data) || data.email is string) &&
             (!('balance' in data) || data.balance is number) &&
             (!('totalSpending' in data) || data.totalSpending is number) &&
             (!('loyaltyPoints' in data) || data.loyaltyPoints is number) &&
             (!('wh1rlCoins' in data) || data.wh1rlCoins is number) &&
             (!('phone' in data) || data.phone is string) &&
             (!('address' in data) || data.address is string) &&
             (!('city' in data) || data.city is string) &&
             (!('country' in data) || data.country is string) &&
             (!('preferredPayment' in data) || data.preferredPayment is string) &&
             (!('role' in data) || data.role in ['admin', 'user']) &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'items', 'total', 'status', 'paymentMethod']) &&
             data.keys().size() >= 5 && data.keys().size() <= 10 &&
             data.userId == request.auth.uid &&
             data.items is list && data.items.size() > 0 &&
             data.total is number && data.total >= 0 &&
             data.paymentMethod in ['cod', 'online', 'balance'] &&
             data.status in ['pending', 'shipped', 'delivered', 'cancelled'] &&
             (!('shippingAddress' in data) || data.shippingAddress is map) &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    function isValidBalanceRequest(data) {
      return data.keys().hasAll(['userId', 'amount', 'status']) &&
             data.keys().size() >= 3 && data.keys().size() <= 6 &&
             data.userId == request.auth.uid &&
             data.amount is number && data.amount > 0 &&
             data.status in ['pending', 'approved', 'rejected'] &&
             (!('proofImageUrl' in data) || data.proofImageUrl is string) &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    function isValidUserPrivateInfo(data) {
       return data.keys().size() <= 5 &&
              (!('email' in data) || data.email is string) &&
              (!('stripeId' in data) || data.stripeId is string);
    }

    // --- Collection Rules ---

    match /products/{productId} {
      allow read: if true; 
      allow create: if isAdmin() && isValidId(productId) && isValidProduct(incoming());
      allow update: if isAdmin() && isValidProduct(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'price', 'costPrice', 'description', 'imageUrl', 'images', 'category', 'stock', 'isFeatured', 'isTrending', 'ratings', 'gender', 'club', 'country'])
      );
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow get: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isEmailVerified() && isValidId(orderId) && isValidOrder(incoming());
      allow update: if isAdmin() && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
        incoming().status in ['pending', 'shipped', 'delivered', 'cancelled']
      );
      allow delete: if false;
    }

    match /balance_requests/{requestId} {
      allow get: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isEmailVerified() && isValidId(requestId) && isValidBalanceRequest(incoming());
      allow update: if isAdmin() && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
        incoming().status in ['approved', 'rejected']
      );
      allow delete: if false;
    }

    match /users/{userId} {
      match /public/profile {
        allow get: if isSignedIn();
        allow list: if isAdmin() || (isSignedIn() && resource.data.role == 'user');
        
        allow create: if isOwner(userId) && isValidUserProfile(incoming()) && (!('balance' in incoming()) || incoming().balance == 0);
        allow update: if (isOwner(userId) && 
                      isValidUserProfile(incoming()) &&
                      (!incoming().diff(existing()).affectedKeys().hasAny(['role', 'createdAt'])))
                      || isAdmin();
        allow delete: if false;
      }

      match /private/info {
        allow read: if isOwner(userId) || isAdmin();
        // Force server timestamp on update/create if added to schema, for now simple write
        allow write: if isOwner(userId) && isValidUserPrivateInfo(incoming());
      }
    }

    match /gift_cards/{cardId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() && isValidGiftCard(incoming());
      allow update: if (isSignedIn() && incoming().status == 'redeemed' && existing().status == 'active') || isAdmin();
      allow delete: if isAdmin();
    }

    match /gift_card_requests/{requestId} {
      allow get: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isEmailVerified() && isValidId(requestId) && isValidGiftCardRequest(incoming());
      allow update: if isAdmin() && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'materializedCode']) &&
        incoming().status in ['approved', 'rejected']
      );
      allow delete: if false;
    }

    match /store_reviews/{reviewId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
